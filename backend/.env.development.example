NODE_ENV=development
APP_NAME=menu-time-backend
APP_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1
LOG_LEVEL=debug
REQUEST_ID_HEADER=x-request-id

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu_time_dev

AUTH_ACCESS_TOKEN_SECRET=dev-access-token-secret-change-me
AUTH_REFRESH_TOKEN_SECRET=dev-refresh-token-secret-change-me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d

WECHAT_APP_ID=demo-app-id
WECHAT_APP_SECRET=demo-app-secret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
MVP_DEFAULT_HOUSEHOLD_NAME=本地开发家庭

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=menu-time-dev
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/menu-time-dev

PG_BOSS_SCHEMA=pgboss
ENABLE_JOB_WORKER=false
SENTRY_DSN=
