NODE_ENV=development
APP_NAME=menu-time-backend
APP_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1
LOG_LEVEL=info
REQUEST_ID_HEADER=x-request-id

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu_time

AUTH_ACCESS_TOKEN_SECRET=first-backend-secret
AUTH_REFRESH_TOKEN_SECRET=refresh-backend-secret
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=30d

WECHAT_APP_ID=demo-app-id
WECHAT_APP_SECRET=demo-app-secret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
MVP_DEFAULT_HOUSEHOLD_NAME=我的家庭

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=menu-time
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/menu-time

PG_BOSS_SCHEMA=pgboss
ENABLE_JOB_WORKER=false
SENTRY_DSN=
