NODE_ENV=test
APP_NAME=menu-time-backend
APP_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1
LOG_LEVEL=warn
REQUEST_ID_HEADER=x-request-id

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu_time_test

AUTH_ACCESS_TOKEN_SECRET=test-access-token-secret-change-me
AUTH_REFRESH_TOKEN_SECRET=test-refresh-token-secret-change-me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=7d

WECHAT_APP_ID=test-app-id
WECHAT_APP_SECRET=test-app-secret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
MVP_DEFAULT_HOUSEHOLD_NAME=测试家庭

S3_ENDPOINT=http://localhost:9000
S3_BUCKET=menu-time-test
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/menu-time-test

PG_BOSS_SCHEMA=pgboss
ENABLE_JOB_WORKER=false
SENTRY_DSN=
