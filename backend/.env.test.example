NODE_ENV=test
APP_NAME=menu-time-backend
APP_BASE_URL=http://localhost:3000
API_PREFIX=/api/v1
LOG_LEVEL=warn
REQUEST_ID_HEADER=x-request-id

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/menu_time_test

AUTH_ACCESS_TOKEN_SECRET=test-access-token-secret-change-me
AUTH_REFRESH_TOKEN_SECRET=test-refresh-token-secret-change-me
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=7d

WECHAT_APP_ID=test-app-id
WECHAT_APP_SECRET=test-app-secret
WECHAT_API_BASE_URL=https://api.weixin.qq.com
MVP_DEFAULT_HOUSEHOLD_NAME=测试家庭

CLOUD_VENDOR=cos
S3_ENDPOINT=https://cos.ap-guangzhou.myqcloud.com
S3_REGION=ap-guangzhou
S3_BUCKET=menu-time-1310659978
S3_ACCESS_KEY=replace-with-cos-secret-id
S3_SECRET_KEY=replace-with-cos-secret-key
S3_PUBLIC_BASE_URL=https://menu-time-1310659978.cos.ap-guangzhou.myqcloud.com
S3_SIGNED_URL_TTL_SECONDS=900
MEDIA_MAX_IMAGE_SIZE_BYTES=5242880
MEDIA_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp

PG_BOSS_SCHEMA=pgboss
ENABLE_JOB_WORKER=false
SENTRY_DSN=
